<%- include('partials/header') %>

<main class="main-content">
    <div class="container">
        <div class="user-container">
            <div class="user-sidebar">
                <div class="user-profile">
                    <div class="avatar-container">
                        <div class="avatar">
                            <% if (user && user.avatar) { %>
                                <img src="<%= user.avatar %>" alt="Avatar" id="user-avatar-img">
                            <% } else { %>
                                <i class="fas fa-user"></i>
                            <% } %>
                        </div>
                        <div class="avatar-badge" onclick="document.getElementById('avatar-input').click()">
                            <i class="fas fa-camera"></i>
                        </div>
                        <input type="file" id="avatar-input" hidden accept="image/*" onchange="uploadAvatar(this)">
                    </div>
                    <h2 class="user-name"><%= user ? user.fullname : 'Khách' %></h2>
                    <p class="user-email"><%= user ? user.email : '' %></p>
                    <span class="member-badge">SMEMBER <%= user ? user.rank.toUpperCase() : 'BRONZE' %></span>
                </div>

                <div class="user-stats">
                    <div class="stat-item">
                        <div class="stat-value"><%= stats.totalOrders %></div>
                        <div class="stat-label">Đơn hàng</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value"><%= stats.wishlistCount %></div>
                        <div class="stat-label">Yêu thích</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value"><%= user ? user.points : 0 %></div>
                        <div class="stat-label">Điểm</div>
                    </div>
                </div>

                <div class="user-menu">
                    <div class="menu-item active" data-tab="dashboard">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Tổng quan</span>
                    </div>
                    <div class="menu-item" data-tab="profile">
                        <i class="fas fa-user"></i>
                        <span>Thông tin tài khoản</span>
                    </div>
                    <div class="menu-item" data-tab="orders">
                        <i class="fas fa-shopping-bag"></i>
                        <span>Đơn hàng của tôi</span>
                        <% if (stats.pendingOrders > 0) { %>
                            <span class="badge"><%= stats.pendingOrders %></span>
                        <% } %>
                    </div>
                    <div class="menu-item" data-tab="addresses">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>Sổ địa chỉ</span>
                    </div>
                    <div class="menu-item" data-tab="wishlist">
                        <i class="fas fa-heart"></i>
                        <span>Yêu thích</span>
                    </div>
                    <div class="menu-item" data-tab="rewards">
                        <i class="fas fa-gem"></i>
                        <span>Điểm thưởng</span>
                    </div>
                    <div class="menu-item" data-tab="settings">
                        <i class="fas fa-cog"></i>
                        <span>Cài đặt</span>
                    </div>
                </div>
            </div>

            <div class="user-content">
                <div class="content-header">
                    <h1 class="content-title">
                        <i class="fas fa-tachometer-alt" id="title-icon"></i>
                        <span id="page-title">Tổng quan</span>
                    </h1>
                    <div class="logout-btn" onclick="logout()">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Đăng xuất</span>
                    </div>
                </div>

                <div class="content-body">
                    <div class="tab-pane active" id="dashboard">
                        <div class="dashboard-grid">
                            <div class="dashboard-card">
                                <div class="card-icon"><i class="fas fa-shopping-bag"></i></div>
                                <div class="card-value"><%= stats.totalOrders %></div>
                                <div class="card-label">Tổng đơn hàng</div>
                            </div>
                            <div class="dashboard-card">
                                <div class="card-icon"><i class="fas fa-truck"></i></div>
                                <div class="card-value"><%= stats.shippingOrders %></div>
                                <div class="card-label">Đang giao</div>
                            </div>
                            <div class="dashboard-card">
                                <div class="card-icon"><i class="fas fa-check-circle"></i></div>
                                <div class="card-value"><%= stats.deliveredOrders %></div>
                                <div class="card-label">Đã giao</div>
                            </div>
                        </div>

                        <div class="recent-orders">
                            <h3 class="section-title">
                                <i class="fas fa-history"></i> Đơn hàng gần đây
                            </h3>
                            <% if (recentOrders && recentOrders.length > 0) { %>
                                <% recentOrders.forEach(order => { %>
                                    <div class="order-item" onclick="viewOrder('<%= order.id %>')">
                                        <div class="order-img"><i class="fas fa-box"></i></div>
                                        <div class="order-info">
                                            <div class="order-name">Đơn hàng <%= order.id %></div>
                                            <div class="order-meta">
                                                <span>Ngày: <%= order.date %></span>
                                            </div>
                                        </div>
                                        <div class="order-status status-<%= order.statusClass %>"><%= order.statusText %></div>
                                        <div class="order-price"><%= order.total.toLocaleString('vi-VN') %>₫</div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p style="text-align: center; opacity: 0.6;">Bạn chưa có đơn hàng nào.</p>
                            <% } %>
                        </div>
                    </div>

                    <div class="tab-pane" id="profile">
                        <h3 class="section-title"><i class="fas fa-user-edit"></i> Thông tin cá nhân</h3>
                        <form class="profile-form" id="update-profile-form">
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Họ và tên</label>
                                    <input type="text" name="fullname" class="form-input" value="<%= user.fullname %>">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Ngày sinh</label>
                                    <input type="date" name="birthday" class="form-input" value="<%= user.birthday %>">
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-input readonly" value="<%= user.email %>" readonly>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Số điện thoại</label>
                                    <input type="tel" name="phone" class="form-input" value="<%= user.phone %>">
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        </form>
                    </div>

                    <div class="tab-pane" id="orders">
                        </div>

                </div>
            </div>
        </div>
    </div>
</main>

<link rel="stylesheet" href="/CSS/User.css">
<script src="/JS/User.js"></script>

<%- include('partials/footer') %>