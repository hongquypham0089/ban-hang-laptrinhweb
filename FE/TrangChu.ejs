<%- include('partials/header') %>

    <!-- Main Content -->
    <main class="main-content">
        <div class="container">
            <!-- Slider Section -->
            <section class="slider">
                <div class="slider-container">
                    <div class="slide slide1 active">
                        <div class="slide-content">
                            <h2>ĐẠI TIỆC GAMING</h2>
                            <p>Giảm giá SỐC lên đến 50% cho toàn bộ phụ kiện gaming. Nâng cấp setup của bạn ngay hôm
                                nay!</p>
                            <a href="#" class="btn">MUA NGAY <i class="fas fa-bolt"></i></a>
                        </div>
                        <div class="slide-image">
                            <i class="fas fa-headset" style="font-size: 200px; color: var(--neon-purple);"></i>
                        </div>
                    </div>
                    <div class="slide slide2">
                        <div class="slide-content">
                            <h2>PC GAMING SIÊU CẤP</h2>
                            <p>Trải nghiệm gaming đỉnh cao với cấu hình RTX 4090, CPU Intel i9. Mượt mà mọi tựa game
                                AAA.</p>
                            <a href="#" class="btn">TÙY CHỈNH NGAY <i class="fas fa-cogs"></i></a>
                        </div>
                        <div class="slide-image">
                            <i class="fas fa-desktop" style="font-size: 200px; color: var(--neon-blue);"></i>
                        </div>
                    </div>
                    <div class="slide slide3">
                        <div class="slide-content">
                            <h2>BÀN PHÍM CƠ RGB</h2>
                            <p>Bàn phím cơ switch Blue, Red, Brown. Hiệu ứng RGB lung linh, cảm giác gõ tuyệt đỉnh.</p>
                            <a href="#" class="btn">KHÁM PHÁ <i class="fas fa-keyboard"></i></a>
                        </div>
                        <div class="slide-image">
                            <i class="fas fa-keyboard" style="font-size: 200px; color: var(--neon-pink);"></i>
                        </div>
                    </div>

                    <div class="slider-controls">
                        <div class="slider-dot active" data-slide="0"></div>
                        <div class="slider-dot" data-slide="1"></div>
                        <div class="slider-dot" data-slide="2"></div>
                    </div>
                </div>
            </section>

            <!-- Filter Section -->
            <section class="filter-section">
                <h3 class="filter-title"><i class="fas fa-filter"></i> LỌC THEO MỤC ĐÍCH</h3>
                <div class="filter-buttons">
                    <button class="filter-btn active" data-filter="all">TẤT CẢ</button>
                    <button class="filter-btn" data-filter="gaming"><i class="fas fa-gamepad"></i> GAMING</button>
                    <button class="filter-btn" data-filter="streaming"><i class="fas fa-video"></i> STREAMING</button>
                    <button class="filter-btn" data-filter="graphic"><i class="fas fa-paint-brush"></i> ĐỒ HỌA</button>
                    <button class="filter-btn" data-filter="study"><i class="fas fa-graduation-cap"></i> HỌC
                        TẬP</button>
                    <button class="filter-btn" data-filter="price-asc"><i class="fas fa-arrow-up"></i> GIÁ TĂNG</button>
                    <button class="filter-btn" data-filter="price-desc"><i class="fas fa-arrow-down"></i> GIÁ
                        GIẢM</button>
                </div>
            </section>

            <!-- Products Section -->
            <section class="products-section">
                <h2 class="section-title"><i class="fas fa-bolt"></i> SẢN PHẨM NỔI BẬT</h2>
                <div class="products-grid" id="products-grid">
                    <!-- Product cards will be generated by JavaScript -->
                </div>
            </section>
        </div>

        <nav class="mobile-nav">
            <ul class="nav-menu">
                <li><a href="#" class="nav-item active"><i class="fas fa-home"></i><span>Trang chủ</span></a></li>
                <li><a href="#" class="nav-item"><i class="fas fa-th-large"></i><span>Danh mục</span></a></li>
                <li><a href="#" class="nav-item"><i class="fas fa-percent"></i><span>Khuyến mãi</span></a></li>
                <li><a href="#" class="nav-item"><i class="fas fa-user"></i><span>Cá nhân</span></a></li>
            </ul>
        </nav>

    </main>
    <link rel="stylesheet" href="/CSS/TrangChu.css">
    <script src="/JS/TrangChu.js"></script>

    <%- include('partials/footer') %>