<%- include('partials/header') %>

<main class="main-content">
    <div class="container">
        <div class="user-container">
            <div class="user-sidebar">
                <div class="user-profile">
                    <div class="avatar-container">
                        <div class="avatar">
                            <img src="" alt="Avatar" id="user-avatar-img">
                            <i class="fas fa-user" id="default-avatar-icon"></i>
                        </div>
                        <div class="avatar-badge" onclick="document.getElementById('avatar-input').click()">
                            <i class="fas fa-camera"></i>
                        </div>
                        <input type="file" id="avatar-input" hidden accept="image/*" onchange="uploadAvatar(this)">
                    </div>
                    <h2 class="user-name">Đang tải...</h2>
                    <p class="user-email">Đang tải...</p>
                    <span class="member-badge">SMEMBER</span>
                </div>

                <div class="user-stats">
                    <div class="stat-item">
                        <div class="stat-value" id="sidebar-total-orders">0</div>
                        <div class="stat-label">Đơn hàng</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value" id="sidebar-points">0</div>
                        <div class="stat-label">Điểm</div>
                    </div>
                </div>

                <div class="user-menu">
                    <div class="menu-item active" data-tab="dashboard">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Tổng quan</span>
                    </div>
                    <div class="menu-item" data-tab="profile">
                        <i class="fas fa-user"></i>
                        <span>Thông tin tài khoản</span>
                    </div>
                    <div class="menu-item" data-tab="orders">
                        <i class="fas fa-shopping-bag"></i>
                        <span>Đơn hàng của tôi</span>
                        <span class="badge" id="menu-pending-orders" style="display: none;">0</span>
                    </div>
                </div>
            </div>

            <div class="user-content">
                <div class="content-header">
                    <h1 class="content-title">
                        <i class="fas fa-tachometer-alt" id="title-icon"></i>
                        <span id="page-title">Tổng quan</span>
                    </h1>
                    <div class="logout-btn" onclick="logout()">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Đăng xuất</span>
                    </div>
                </div>

                <div class="content-body">
                    <div class="tab-pane active" id="dashboard">
                        <div class="dashboard-grid">
                            <div class="dashboard-card">
                                <div class="card-icon"><i class="fas fa-shopping-bag"></i></div>
                                <div class="card-value" id="card-total-orders">0</div>
                                <div class="card-label">Tổng đơn hàng</div>
                            </div>
                            <div class="dashboard-card">
                                <div class="card-icon"><i class="fas fa-truck"></i></div>
                                <div class="card-value" id="card-shipping-orders">0</div>
                                <div class="card-label">Đang giao</div>
                            </div>
                            <div class="dashboard-card">
                                <div class="card-icon"><i class="fas fa-check-circle"></i></div>
                                <div class="card-value" id="card-delivered-orders">0</div>
                                <div class="card-label">Đã giao</div>
                            </div>
                        </div>

                        <div class="recent-orders">
                            <p style="text-align: center; opacity: 0.6;">Đang tải danh sách đơn hàng...</p>
                        </div>
                    </div>

                    <div class="tab-pane" id="profile">
                        <h3 class="section-title"><i class="fas fa-user-edit"></i> Thông tin cá nhân</h3>
                        <form class="profile-form" id="update-profile-form">
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Họ và tên</label>
                                    <input type="text" id="profile-fullname" name="fullname" class="form-input" value="">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Ngày sinh</label>
                                    <input type="date" id="profile-birthday" name="birthday" class="form-input" value="">
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Email</label>
                                    <input type="email" id="profile-email" class="form-input readonly" value="" readonly>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Số điện thoại</label>
                                    <input type="tel" id="profile-phone" name="phone" class="form-input" value="">
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Địa chỉ</label>
                                <input type="text" id="profile-address" name="address" class="form-input" value="">
                            </div>
                            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        </form>
                    </div>

                    <div class="tab-pane" id="orders">
                        </div>

                </div>
            </div>
        </div>
    </div>
</main>

<link rel="stylesheet" href="/CSS/User.css">
<script src="/JS/User.js"></script>

<%- include('partials/footer') %>