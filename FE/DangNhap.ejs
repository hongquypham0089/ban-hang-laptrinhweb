<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link
    href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Exo+2:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
<div class="container">
    <div class="auth-container">
        <!-- Welcome Section -->
        <div class="welcome-section">
            <div class="logo">
                <div class="logo-icon">
                    <i class="fas fa-gamepad"></i>
                </div>
                <div class="logo-text">Computer - N9</div>
            </div>

            <h1 class="welcome-title">Chào mừng đến với <span>Thế giới Gaming</span></h1>

            <p class="welcome-description">
                Khám phá thế giới gaming đỉnh cao với những sản phẩm công nghệ mới nhất.
                Tham gia cộng đồng N9 để nhận ưu đãi đặc biệt và cập nhật tin tức gaming nhanh nhất.
            </p>

            <div class="features-list">
                <div class="feature-item">
                    <i class="fas fa-bolt"></i>
                    <span>Ưu đãi đặc biệt cho thành viên SMEMBER</span>
                </div>
                <div class="feature-item">
                    <i class="fas fa-shipping-fast"></i>
                    <span>Miễn phí vận chuyển cho đơn từ 5 triệu</span>
                </div>
                <div class="feature-item">
                    <i class="fas fa-gift"></i>
                    <span>Tích điểm đổi quà với mỗi giao dịch</span>
                </div>
                <div class="feature-item">
                    <i class="fas fa-headset"></i>
                    <span>Hỗ trợ 24/7 từ đội ngũ chuyên nghiệp</span>
                </div>
            </div>

            <div class="contact-info">
                <div class="contact-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Số 504 Đại lộ Bình Dương, P. Phú Lợi, TP. Hồ Chí Minh</span>
                </div>
                <div class="contact-item">
                    <i class="fas fa-phone"></i>
                    <span>Hotline: 0789 269 219 - 0274 6 511 756</span>
                </div>
                <div class="contact-item">
                    <i class="fas fa-envelope"></i>
                    <span>Email: support@computern9.vn</span>
                </div>
            </div>
        </div>

        <!-- Form Section -->
        <div class="form-section" id="form-section">
            <div class="form-container">
                <!-- Login Form -->
                <div class="login-form" id="login-form">
                    <h2 class="form-title">Đăng nhập</h2>
                    <p class="form-subtitle"> Chào mừng bạn đến với cửa hàng! chúc bạn một ngày mua sắm vui vẻ. </p>

                    <div class="form-group">
                        <label class="form-label">Tài khoản đăng nhập</label>
                        <div class="input-with-icon">
                            <input type="text" class="form-input" id="login-identifier"
                                placeholder="Tài khoản đăng nhập">
                            <i class="fas fa-user input-icon"></i>
                        </div>
                        <div class="error-message" id="login-identifier-error"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mật khẩu</label>
                        <div class="input-with-icon">
                            <input type="password" class="form-input" id="login-password" placeholder="Nhập mật khẩu">
                            <i class="fas fa-eye password-toggle input-icon" id="toggle-login-password"></i>
                        </div>
                        <div class="error-message" id="login-password-error"></div>
                    </div>

                    <div class="form-options">
                        <label class="remember-me">
                            <input type="checkbox" class="checkbox" id="remember-me">
                            <span>Ghi nhớ đăng nhập</span>
                        </label>
                        <a href="#" class="forgot-password">Quên mật khẩu?</a>
                    </div>

                    <button class="btn login-btn" id="login-submit">Đăng nhập</button>

                    <div class="divider">
                        <span>Hoặc đăng nhập với</span>
                    </div>

                    <div class="social-login">
                        <button class="social-btn google">
                            <i class="fab fa-google"></i>
                            Google
                        </button>
                        <button class="social-btn zalo">
                            <i class="fab fa-facebook"></i>
                            Facebook
                        </button>
                    </div>

                    <button class="btn toggle-btn" id="show-register">Đăng ký tài khoản mới</button>
                </div>

                <!-- Register Form -->
                <div class="register-form" id="register-form">
                    <h2 class="register-title">Đăng ký trở thành SMEMBER</h2>
                    <!-- <div class="divider">
                            <span>Đăng ký bằng tài khoản mạng xã hội</span>
                        </div>
                        
                        <div class="social-login">
                            <button class="social-btn google">
                                <i class="fab fa-google"></i>
                                Google
                            </button>
                            <button class="social-btn zalo">
                                <i class="fab fa-facebook"></i>
                                Facebook
                            </button>
                        </div>
                        
                        <div class="divider">
                            <span>Hoặc điền thông tin sau</span>
                        </div> -->

                    <form id="register-form-data">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Họ và tên *</label>
                                <input type="text" class="form-input" id="register-name"
                                    placeholder="Nhập họ và tên đầy đủ">
                                <div class="error-message" id="register-name-error"></div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Ngày sinh</label>
                                <input type="date" class="form-input" id="register-birthday">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Số điện thoại *</label>
                                <input type="tel" class="form-input" id="register-phone"
                                    placeholder="Nhập số điện thoại">
                                <div class="error-message" id="register-phone-error"></div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Email *</label>
                                <input type="email" class="form-input" id="register-email"
                                    placeholder="Nhập địa chỉ email">
                                <div class="error-message" id="register-email-error"></div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Tạo mật khẩu *</label>
                            <div class="input-with-icon">
                                <input type="password" class="form-input" id="register-password"
                                    placeholder="Mật khẩu tối thiểu 6 ký tự, có ít nhất 1 chữ số">
                                <i class="fas fa-eye password-toggle input-icon" id="toggle-register-password"></i>
                            </div>

                            <div class="error-message" id="register-password-error"></div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Xác nhận mật khẩu *</label>
                            <div class="input-with-icon">
                                <input type="password" class="form-input" id="register-confirm-password"
                                    placeholder="Nhập lại mật khẩu">
                                <i class="fas fa-eye password-toggle input-icon" id="toggle-confirm-password"></i>
                            </div>
                            <div class="error-message" id="register-confirm-password-error"></div>
                        </div>

                        <div class="terms-agreement">
                            <input type="checkbox" class="checkbox" id="terms-agreement">
                            <span>Tôi đồng ý với <a href="#">Điều khoản dịch vụ</a> và <a href="#">Chính sách bảo
                                    mật</a> của Computer N9</span>
                        </div>

                        <button type="submit" class="btn register-btn" id="register-submit">Đăng ký tài
                            khoản</button>
                    </form>

                    <a href="#" class="back-to-login" id="back-to-login">
                        <i class="fas fa-arrow-left"></i>
                        Quay lại đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<a href="/TrangChu.ejs" class="floating-home-btn" title="Quay lại Trang Chủ">
    <div class="btn-content">
        <i class="fas fa-home"></i>
        <span>TRANG CHỦ</span>
    </div>
    <div class="btn-glow"></div>
</a>

<link rel="stylesheet" href="/CSS/DangNhap.css">
<script src="/JS/DangNhap.js"></script>